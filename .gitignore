# =============================================================================
# Causal Demand Intelligence System — .gitignore
# =============================================================================

# Data files (large, not versioned)
data/raw/
data/processed/
data/external/
data/models/
*.csv
*.parquet
*.db
*.duckdb

# Keep .gitkeep placeholders
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!data/models/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Environment variables
.env
.env.local
*.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Reports / outputs (generated)
reports/figures/*.png
reports/figures/*.pdf
reports/powerbi/*.pbix

# Logs
*.log
logs/

# R
.Rhistory
.RData
.Rproj.user/
*.Rproj
